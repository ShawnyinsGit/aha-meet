<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- whisper.cpp Metal backend JITs GPU kernels at runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- ggml-metal allocates RWX pages for compiled kernels -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- We bundle libwhisper / libggml under @loader_path; they are signed by us
       (not Apple), so the helper needs to skip library validation. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
